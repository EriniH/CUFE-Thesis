%%
%% Produces numeric citations: [1], [2], [1, chap. 2], etc.
%%
%% Usage in your document preamble:
%%   \usepackage[style=cufe, backend=biber]{biblatex}
%%
\ProvidesFile{cufe.cbx}
  [2025/01/01 v1.0 CUFE BibLaTeX citation style]

\RequireCitationStyle{numeric-comp}

\endinput
